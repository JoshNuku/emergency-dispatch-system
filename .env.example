# ============================================
# Emergency Dispatch System - Environment Config
# ============================================
# Copy this file to .env and fill in your values

# ---- Shared ----
JWT_SECRET=your-super-secret-jwt-key-change-this
ENVIRONMENT=development
SEED_DEMO_DATA=true
DEMO_USER_PASSWORD=dispatch1234

# ---- Auth Service (:8081) ----
AUTH_DB_HOST=localhost
AUTH_DB_PORT=5432
AUTH_DB_USER=postgres
AUTH_DB_PASSWORD=54671
AUTH_DB_NAME=auth_db
AUTH_SERVICE_PORT=8081

# ---- Incident Service (:8082) ----
INCIDENT_DB_HOST=localhost
INCIDENT_DB_PORT=5432
INCIDENT_DB_USER=postgres
INCIDENT_DB_PASSWORD=54671
INCIDENT_DB_NAME=incident_db
INCIDENT_SERVICE_PORT=8082
DISPATCH_SERVICE_URL=http://localhost:8083

# ---- Dispatch Tracking Service (:8083) ----
DISPATCH_DB_HOST=localhost
DISPATCH_DB_PORT=5432
DISPATCH_DB_USER=postgres
DISPATCH_DB_PASSWORD=54671
DISPATCH_DB_NAME=dispatch_db
DISPATCH_SERVICE_PORT=8083

# ---- Analytics Service (:8084) ----
ANALYTICS_DB_HOST=localhost
ANALYTICS_DB_PORT=5432
ANALYTICS_DB_USER=postgres
ANALYTICS_DB_PASSWORD=54671
ANALYTICS_DB_NAME=analytics_db
ANALYTICS_SERVICE_PORT=8084

# ---- Real-time Gateway (:8085) ----
GATEWAY_PORT=8085

# ---- RabbitMQ (CloudAMQP) ----
RABBITMQ_URL=amqps://user:pass@hostname/vhost

# ---- Frontend (:3000) ----
NEXT_PUBLIC_AUTH_API_URL=http://localhost:8081
NEXT_PUBLIC_INCIDENT_API_URL=http://localhost:8082
NEXT_PUBLIC_DISPATCH_API_URL=http://localhost:8083
NEXT_PUBLIC_ANALYTICS_API_URL=http://localhost:8084
NEXT_PUBLIC_WS_URL=ws://localhost:8085
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_public_token_here
